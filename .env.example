# ============================================
# FBA Lead Generator - Environment Config
# ============================================

# Port (Railway sets this automatically)
PORT=3000

# Data provider: mock | keepa | rainforest
# - mock: no API needed, realistic sample data (default for demo)
# - keepa: requires KEEPA_API_KEY
# - rainforest: requires RAINFOREST_API_KEY
DATA_PROVIDER=mock

# Keepa API - https://keepa.com/#!api
# Needed for: sales rank history, price history, estimated monthly sales
# KEEPA_API_KEY=

# Rainforest API - https://www.rainforestapi.com/
# Needed for: live product data, search, reviews
# RAINFOREST_API_KEY=
